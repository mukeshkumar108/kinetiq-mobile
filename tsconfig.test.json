{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "outDir": ".test-dist",
    "rootDir": ".",
    "noEmit": false,
    "jsx": "react-jsx",
    "isolatedModules": false
  },
  "include": [
    "tests/**/*.ts",
    "src/api/query-keys.ts",
    "src/api/invalidate.ts",
    "src/shared/types/api.ts"
  ]
}
